{
    "chat.agent.maxRequests": 250,
    "github.copilot.chat.codesearch.enabled": true,
    "github.copilot.chat.agent.thinkingTool": true,
    "github.copilot.chat.generateTests.codeLens": true,
    // ========================================
    // ZebTrack-AI Quick Access
    // ========================================
    // File associations
    "files.associations": {
        "CLAUDE.md": "markdown",
        "WIDGETS.md": "markdown",
        "*.yaml": "yaml"
    },
    // Quick navigation bookmarks (use File Explorer → right-click → "Reveal in File Explorer")
    // Key files for development:
    // Core Architecture
    // - src/zebtrack/core/main_view_model.py (Application orchestrator)
    // - src/zebtrack/core/state_manager.py (Centralized state)
    // - src/zebtrack/core/project_service.py (Project I/O)
    // - src/zebtrack/core/detector.py (AI model abstraction)
    // UI Components
    // - src/zebtrack/ui/gui.py (Main window)
    // - src/zebtrack/ui/wizard/wizard_dialog.py (Project creation wizard)
    // - src/zebtrack/ui/collapsible_frame.py (Reusable collapsible widget)
    // Wizard Steps (LIVE projects)
    // - src/zebtrack/ui/wizard/discovery_step.py
    // - src/zebtrack/ui/wizard/experimental_design_step.py (NumberInput widget)
    // - src/zebtrack/ui/wizard/live_config_step.py (Arduino/Camera detection)
    // - src/zebtrack/ui/wizard/calibration_step.py
    // - src/zebtrack/ui/wizard/model_selection_step.py (PanedWindow layout)
    // - src/zebtrack/ui/wizard/confirmation_step.py (Text widget optimization)
    // Documentation
    // - CLAUDE.md (Development guide)
    // - docs/WIDGETS.md (UI widgets catalog)
    // - docs/WIZARD_LIVE_IMPROVEMENTS.md (Phase 0-4 features)
    // - README_TESTS.md (Testing guide)
    // Search scopes for common tasks
    "search.exclude": {
        "**/node_modules": true,
        "**/bower_components": true,
        "**/*.code-search": true,
        "**/openvino_model_cache": true,
        "**/__pycache__": true,
        "**/*.pyc": true,
        "**/htmlcov": true,
        "**/MagicMock": true,
        "**/live_analysis_sessions": true,
        "**/logs": true,
        "**/.ruff_cache": true,
        "**/.pytest_cache": true,
        "**/.hypothesis": true
    },
    // File watcher exclusions (critical for OneDrive workspace performance)
    "files.watcherExclude": {
        "**/openvino_model_cache/**": true,
        "**/htmlcov/**": true,
        "**/MagicMock/**": true,
        "**/live_analysis_sessions/**": true,
        "**/logs/**": true,
        "**/__pycache__/**": true,
        "**/.ruff_cache/**": true,
        "**/.pytest_cache/**": true,
        "**/.hypothesis/**": true,
        "**/.mypy_cache/**": true
    },
    // Python settings
    "python.analysis.extraPaths": [
        "./src"
    ],
    // Pylance performance (optimized for 32GB+ RAM systems)
    "python.analysis.persistAllIndices": true,
    "python.analysis.indexing.maxFileSize": 10000,
    "python.defaultInterpreterPath": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
    "python.terminal.activateEnvironment": true,
    "python.terminal.activateEnvInCurrentTerminal": true,
    "terminal.integrated.defaultProfile.windows": "PowerShell",
    "terminal.integrated.scrollback": 10000,
    "terminal.integrated.profiles.windows": {
        "PowerShell": {
            "source": "PowerShell",
            "icon": "terminal-powershell"
        }
    },
    "terminal.integrated.enablePersistentSessions": false,
    "terminal.integrated.environmentChangesRelaunch": "auto",
    // Testing configuration (v2.1 hang fixes + v3.x: 2806+ tests)
    // Fast suite  : ~2806 tests  (excludes gui / slow / ttkbootstrap_singleton)
    // GUI suite   : ~949  tests  (run separately: pytest -m gui -n0)
    // Slow suite  : ~35   tests  (run separately: pytest -m slow)
    // IMPORTANT: --override-ini=addopts= clears pytest.ini addopts so we must
    //            re-declare timeout settings here to prevent Test Explorer hangs.
    "python.testing.pytestEnabled": true,
    "python.testing.unittestEnabled": false,
    "python.testing.pytestArgs": [
        "--override-ini=addopts=", // Clear pytest.ini addopts (coverage, -n0, etc.)
        "--no-cov", // Disable coverage for faster discovery & run in Test Explorer
        "-n0", // Sequential in Test Explorer (avoids xdist output buffering issues)
        "--timeout=300", // Required: re-declare since addopts was cleared
        "--timeout-method=thread", // Required: thread-based timeout (safe for Tkinter)
        "-m",
        "not (gui or slow or ttkbootstrap_singleton)" // Exclude long-running suites
    ],
    // Editor hints
    "editor.rulers": [
        100
    ], // Ruff line length
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    // Ensure Markdown also trims whitespace (project uses markdownlint, not trailing-space <br>)
    "[markdown]": {
        "files.trimTrailingWhitespace": true
    },
    // ========================================
    // Ruff Linter & Formatter (Native Extension)
    // ========================================
    "[python]": {
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "explicit",
            "source.organizeImports.ruff": "explicit"
        },
        "editor.defaultFormatter": "charliermarsh.ruff"
    },
    // Ruff configuration (reads from pyproject.toml by default)
    "ruff.enable": true,
    "ruff.organizeImports": true,
    "ruff.fixAll": true,
    // Line length is configured in pyproject.toml (line-length = 100)
    // No need to duplicate here with deprecated args
    // Ruff is the sole formatter/linter (conflicting tools excluded in extensions.json)
    // ========================================
    // YAML Extension (Red Hat) Configuration
    // ========================================
    "yaml.schemas": {
        "https://json.schemastore.org/github-workflow.json": ".github/workflows/*.yml"
    },
    "yaml.validate": true,
    "yaml.schemaStore.enable": true,
    // ========================================
    // Mypy (Matan Gover) — Daemon-based type checking
    // ========================================
    "mypy.runUsingActiveInterpreter": true,
    // ========================================
    // Error Lens — Inline diagnostics
    // ========================================
    "errorLens.enabledDiagnosticLevels": [
        "error",
        "warning"
    ],
    "errorLens.excludeBySource": [
        "cSpell"
    ],
    "errorLens.delay": 500,
    // ========================================
    // TODO Tree — Track TODO/FIXME/HACK in code
    // ========================================
    "todo-tree.general.tags": [
        "TODO",
        "FIXME",
        "HACK",
        "BUG",
        "XXX",
        "DEPRECATED"
    ],
    "todo-tree.filtering.excludeGlobs": [
        "**/node_modules/**",
        "**/__pycache__/**",
        "**/openvino_model_cache/**",
        "**/htmlcov/**",
        "**/docs/archive/**"
    ],
    "todo-tree.tree.showCountsInTree": true,
    // ========================================
    // GitLens — Git supercharged (replaces Git History)
    // ========================================
    "gitlens.codeLens.enabled": true,
    "gitlens.currentLine.enabled": true,
    "gitlens.hovers.currentLine.over": "line",
    "gitlens.blame.format": "${author|10} ${agoOrDate|14-}",
    // ========================================
    // Jupyter — Notebook support for data analysis
    // ========================================
    "jupyter.askForKernelRestart": false,
    "notebook.output.scrolling": true,
    // ========================================
    // Code Spell Checker
    // ========================================
    "cSpell.language": "en,pt,pt-BR",
    "cSpell.words": [
        "agpl",
        "arduino",
        "bbox",
        "bootstrapper",
        "botsort",
        "bytetrack",
        "charliermarsh",
        "codecov",
        "Commitlint",
        "danio",
        "dataclass",
        "Diátaxis",
        "docx",
        "docxcompose",
        "docxtpl",
        "drerio",
        "DSHOW",
        "fapesp",
        "ffmpeg",
        "fourcc",
        "geotaxis",
        "golay",
        "Gover",
        "hashFiles",
        "imdecode",
        "IMREAD",
        "imshow",
        "imwrite",
        "iou",
        "isort",
        "kalman",
        "LANCZOS",
        "libavcodec",
        "libopencv",
        "logai",
        "Matan",
        "matplotlib",
        "MSMF",
        "mvvm",
        "mypy",
        "networkx",
        "nireq",
        "nms",
        "numpy",
        "opencv",
        "openpyxl",
        "openvino",
        "parquet",
        "pathlib",
        "plotly",
        "polib",
        "psutil",
        "pyarrow",
        "pydantic",
        "Pylint",
        "pyproject",
        "pyserial",
        "pytest",
        "pytorch",
        "pyyaml",
        "rerio",
        "roi",
        "ruff",
        "savitzky",
        "scipy",
        "seaborn",
        "servernum",
        "sessionfinish",
        "Setext",
        "structlog",
        "thigmotaxis",
        "tkinter",
        "Treeview",
        "ttkbootstrap",
        "ultralytics",
        "venv",
        "viewmodel",
        "virtualenvs",
        "xvfb",
        "yaml",
        "yolo",
        "zebrafish",
        "zebtrack"
    ],
    "powershell.startAutomatically": false,
    "powershell.integratedConsole.startInBackground": true,
    "powershell.integratedConsole.showOnStartup": false
}
