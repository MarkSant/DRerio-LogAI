{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Shared Claude Code settings for DRerio LogAI. Hooks live here so every developer/agent gets them. User-specific permissions belong in settings.local.json (which is git-ignored).",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/ruff-fix.ps1"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/block-push-main.ps1"
          }
        ]
      }
    ]
  }
}
